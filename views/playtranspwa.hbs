<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <meta name="theme-color" content="#4285F4">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>PWA Layout</title>
    <link rel="stylesheet" href="/css/playtranspwa.css">
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <style>
        /* Summary Modal Styles */
        #summary-modal {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0,0,0,0.8);
        }
        .modal-content {
            background-color: #fefefe;
            margin: 5% auto;
            padding: 20px;
            border: 1px solid #888;
            width: 85%;
            max-width: 800px;
            border-radius: 10px;
            color: #333;
            font-family: sans-serif;
            line-height: 1.6;
            max-height: 80vh;
            overflow-y: auto;
        }
        .close {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }
        .close:hover,
        .close:focus {
            color: black;
            text-decoration: none;
        }
        #summary-selector {
            margin-bottom: 15px;
            border-bottom: 1px solid #eee;
            padding-bottom: 10px;
        }
        #summary-selector button {
            padding: 5px 10px;
            margin-right: 5px;
            cursor: pointer;
            border: 1px solid #ccc;
            background: #f9f9f9;
            border-radius: 4px;
        }
        #summary-selector button.active {
            background: #4285F4;
            color: white;
            border-color: #4285F4;
        }
        #summary-text {
            margin-top: 10px;
        }
        #summary-text h1, #summary-text h2, #summary-text h3 {
            border-bottom: 1px solid #eee;
            padding-bottom: 5px;
        }
        #timeDisplay {
            cursor: pointer;
            text-decoration: underline;
            text-decoration-style: dotted;
        }
        /* Notes Modal Styles */
        #notes-modal {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0,0,0,0.8);
        }
        .notes-close {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }
        .notes-close:hover,
        .notes-close:focus {
            color: black;
            text-decoration: none;
        }
        #notes-history .stat-item {
            display: inline-block;
            margin-right: 16px;
        }
        #notes-display .note-tag {
            display: inline-block;
            padding: 1px 6px;
            border-radius: 8px;
            background: #e0e0e0;
            font-size: 0.75rem;
            color: #333;
            margin-right: 4px;
        }
        #notes-tags .note-tag {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 8px;
            background: #e0e0e0;
            font-size: 0.8rem;
            color: #333;
            margin-right: 4px;
        }
        .tag-badge-edit {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 8px;
            background: #e0e0e0;
            font-size: 0.8rem;
            color: #333;
            margin-right: 4px;
            margin-bottom: 4px;
        }
        .tag-badge-edit .tag-remove {
            cursor: pointer;
            margin-left: 4px;
            color: #999;
            font-weight: bold;
        }
        .tag-badge-edit .tag-remove:hover {
            color: #e00;
        }
        #notes-tag-suggestions div {
            padding: 4px 8px;
            cursor: pointer;
            font-size: 0.85rem;
        }
        #notes-tag-suggestions div:hover,
        #notes-tag-suggestions div.active {
            background: #e8e8e8;
        }
        #notes-display h1, #notes-display h2, #notes-display h3 {
            border-bottom: 1px solid #eee;
            padding-bottom: 5px;
        }
    </style>
</head>
<body>
    <!-- Summary Modal -->
    <div id="summary-modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <div id="summary-selector" style="display: none;"></div>
            <div id="summary-text">Loading summary...</div>
        </div>
    </div>

    <!-- Notes Modal -->
    <div id="notes-modal">
        <div class="modal-content">
            <span class="notes-close">&times;</span>
            <div id="notes-history" style="margin-bottom: 12px; padding-bottom: 10px; border-bottom: 1px solid #eee; font-size: 0.9em; color: #666;"></div>
            <div id="notes-tags" style="margin-bottom: 10px;"></div>
            <div id="notes-tag-editor" style="display:none; margin-bottom: 10px;">
                <div id="notes-tag-badges" style="margin-bottom: 6px;"></div>
                <div style="position:relative; display:inline-block;">
                    <input type="text" id="notes-tag-input" placeholder="Add tag..." style="padding:4px 8px; border:1px solid #ccc; border-radius:4px; font-size:0.85rem; width: 150px;">
                    <div id="notes-tag-suggestions" style="display:none; position:absolute; top:100%; left:0; right:0; background:white; border:1px solid #ccc; border-radius:0 0 4px 4px; max-height:150px; overflow-y:auto; z-index:10;"></div>
                </div>
            </div>
            <div id="notes-display"></div>
            <div style="margin-top: 10px;"><button id="notes-edit" style="padding:6px 14px; cursor:pointer;">✏️ Edit</button></div>
            <div id="notes-editor" style="display:none;">
                <textarea id="notes-textarea" style="width:100%; min-height:300px; font-family:monospace; font-size:14px; padding:8px; box-sizing:border-box;"></textarea>
                <div style="margin-top: 10px;">
                    <button id="notes-save" style="padding:6px 14px; cursor:pointer;">Save</button>
                    <button id="notes-cancel" style="padding:6px 14px; cursor:pointer; margin-left:6px;">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <div id="back-to-search-container" style="display: none; padding: 10px;">
        <a href="#" onclick="history.back(); return false;" style="text-decoration: none; font-size: 1.2em;">&larr; Back to Search</a>
    </div>
    <div id="title" class="title-bar"></div>
    <!-- Top button bar -->
    <div class="button-bar" id="audio-container">
        <div> <span id=podtitle2></span></div>
            <div>
        <audio id="audio" controls>
            <source src="{{mp3file}}" type="audio/mpeg">
            Your browser does not support the audio element.
        </audio>
        <div>
     <button id="back">⬆️</button>  .............  <span id="timeDisplay">0:00 / 0:00</span> ............. <button id="top">⏫</button>
     <p></p>
    
            <input type="range" id="seekSlider" min="0" value="0" step="0.1" disabled>
         </div>
        </div>
             <div>

            <button id="toggle-mode">👂</button>
            <button id="rewind">⏪ -5s</button>
            <button id="playpause">▶</button>
            <button id="finished">✅</button>
            <button id="notes-btn"{{#unless hasNotes}} style="opacity: 0.5;"{{/unless}}>{{#if hasNotes}}📝{{else}}📄{{/if}}</button>
        
            </div>
  
    </div>

   
    
    <!-- Middle scrolling text area -->
    <div class="content-area" id="transcription">
  
    </div>
    
    <!-- Bottom status display -->
    <div class="status-bar">
          
                    <!-- Display the podcast title and time listened today,
                    this should be updated every time we send a time listened update to the server -->

                    <span id=podtitle1></span> [<span id="timeListenedToday">{{timeListenedToday}}</span>] 
        <div class="status-item">
            
            {{#if info.published}}
            <span>Published: {{info.published}}</span>
            {{/if}}
        </div>

    </div>

    <script>
     
 const FONTMAX = 40;
        const FONTMIN = 12;


        window.onload = function () {
            window.scrollTo(0, 0);
            localStorage.setItem("lastPage", window.location.href);

        };

        function adjustPadding() {
            const audioContainer = document.getElementById("audio-container");
            const transcriptionContainer = document.getElementById("transcription");

            // Get the exact height of the fixed controls
            const audioHeight = audioContainer.offsetHeight;

            // Apply dynamic padding
            transcriptionContainer.style.paddingTop = `${audioHeight + 20}px`; // Add extra spacing for safety
        }

        // Adjust on load and resize
        window.addEventListener("load", adjustPadding);
        window.addEventListener("resize", adjustPadding);
        document.addEventListener("DOMContentLoaded", () => {

            // Show back button if coming from search
            const params = new URLSearchParams(window.location.search);
            if (params.get('from') === 'search') {
                const backButtonContainer = document.getElementById('back-to-search-container');
                if (backButtonContainer) {
                    backButtonContainer.style.display = 'block';
                }
            }


            let timeLastOpened = new Date()
            let finished = {{ meta.finished }}
        
    let lastTime = 0
    const listenSecondsUpdateInterval = 10; // seconds

    const decodedTitle = decodeURIComponent("{{{mp3file}}}") + " - " + "[{{transcriptionMethod}}]" 
        document.getElementById("podtitle1").textContent = decodedTitle
        document.getElementById("podtitle2").textContent = decodedTitle
        document.title = decodedTitle 


        const audio = document.getElementById("audio");
        audio.controls = false
        let seekSlider = document.getElementById("seekSlider");
        const transcriptionContainer = document.getElementById("transcription");

        const backBtn = document.getElementById("back");
        const topBtn = document.getElementById("top");
        const playpauseBtn = document.getElementById("playpause");
        // const pauseBtn = document.getElementById("pause");
        const rewindBtn = document.getElementById("rewind");
        const finishBtn = document.getElementById("finished");
        const timeDisplay = document.getElementById("timeDisplay");
        const toggleModeBtn = document.getElementById("toggle-mode");

        // Summary Modal Logic
        const modal = document.getElementById("summary-modal");
        const summaryText = document.getElementById("summary-text");
        const closeSpan = document.querySelector(".close");

        timeDisplay.addEventListener("click", () => {
            modal.style.display = "block";
            summaryText.innerHTML = "Loading...";
            const selector = document.getElementById("summary-selector");
            selector.style.display = "none";
            selector.innerHTML = "";

            const mp3Path = "{{{mp3file}}}";
            const parts = mp3Path.split("/");
            const epEncoded = parts[parts.length - 1].replace(".mp3", "");

            fetch(`/list-summaries/{{pod}}/${epEncoded}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success && data.summaries.length > 0) {
                        if (data.summaries.length > 1) {
                            selector.style.display = "block";
                            data.summaries.forEach(type => {
                                const btn = document.createElement("button");
                                btn.textContent = type.charAt(0).toUpperCase() + type.slice(1);
                                btn.dataset.type = type;
                                btn.onclick = () => fetchSummary(epEncoded, type);
                                selector.appendChild(btn);
                            });
                        }
                        // Default to 'english' if present, otherwise the first one
                        const initialType = data.summaries.includes('english') ? 'english' : data.summaries[0];
                        fetchSummary(epEncoded, initialType);
                    } else {
                        summaryText.innerHTML = "<p>No summary available for this episode.</p>";
                    }
                })
                .catch(error => {
                    console.error("Error listing summaries:", error);
                    summaryText.innerHTML = "<p>Error loading summaries.</p>";
                });
        });

        function fetchSummary(epEncoded, type) {
            const summaryText = document.getElementById("summary-text");
            const selector = document.getElementById("summary-selector");
            
            // Highlight active button
            selector.querySelectorAll("button").forEach(btn => {
                if (btn.dataset.type === type) btn.classList.add("active");
                else btn.classList.remove("active");
            });

            summaryText.innerHTML = "Loading " + (type === 'english' ? '' : type) + " summary...";
            fetch(`/get-summary/{{pod}}/${epEncoded}?type=${type}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        summaryText.innerHTML = marked.parse(data.summary);
                    } else {
                        summaryText.innerHTML = `<p>${data.message}</p>`;
                    }
                })
                .catch(error => {
                    console.error("Error fetching summary:", error);
                    summaryText.innerHTML = "<p>Error loading summary.</p>";
                });
        }

        closeSpan.onclick = function() {
            modal.style.display = "none";
        }

        window.onclick = function(event) {
            if (event.target == modal) {
                modal.style.display = "none";
            }
        }

        // Notes Modal Logic
        const notesModal = document.getElementById("notes-modal");
        const notesDisplay = document.getElementById("notes-display");
        const notesEditor = document.getElementById("notes-editor");
        const notesTextarea = document.getElementById("notes-textarea");
        const notesHistory = document.getElementById("notes-history");
        const notesTagsDisplay = document.getElementById("notes-tags");
        const notesTagEditor = document.getElementById("notes-tag-editor");
        const notesTagBadges = document.getElementById("notes-tag-badges");
        const notesTagInput = document.getElementById("notes-tag-input");
        const notesCloseBtn = document.querySelector(".notes-close");
        const notesBtn = document.getElementById("notes-btn");
        const notesSaveBtn = document.getElementById("notes-save");
        const notesCancelBtn = document.getElementById("notes-cancel");

        let currentTags = [];

        function formatSecondsToHM(totalSeconds) {
            const h = Math.floor(totalSeconds / 3600);
            const m = Math.floor((totalSeconds % 3600) / 60);
            if (h > 0) return `${h}h ${m}m`;
            return `${m}m`;
        }

        function renderNoteTags(container, tags) {
            container.innerHTML = tags.map(t => `<span class="note-tag">${t}</span>`).join("");
        }

        function renderTagEditor() {
            notesTagBadges.innerHTML = currentTags.map((t, i) =>
                `<span class="tag-badge-edit">${t}<span class="tag-remove" data-idx="${i}">&times;</span></span>`
            ).join("");
            notesTagBadges.querySelectorAll(".tag-remove").forEach(btn => {
                btn.addEventListener("click", () => {
                    currentTags.splice(parseInt(btn.dataset.idx), 1);
                    renderTagEditor();
                });
            });
        }

        function addTag() {
            const val = notesTagInput.value.trim();
            if (val && !currentTags.includes(val)) {
                currentTags.push(val);
                renderTagEditor();
            }
            notesTagInput.value = "";
        }

        function buildFrontmatter(tags, body) {
            if (tags.length === 0) return body;
            const yaml = "---\ntags:\n" + tags.map(t => `  - ${t}`).join("\n") + "\n---\n";
            return yaml + body;
        }

        const epMp3Path = "{{{mp3file}}}";
        const epParts = epMp3Path.split("/");
        const epName = epParts[epParts.length - 1].replace(".mp3", "");

        notesBtn.addEventListener("click", () => {
            notesModal.style.display = "block";
            notesEditor.style.display = "none";
            notesTagEditor.style.display = "none";
            notesDisplay.style.display = "block";
            notesDisplay.innerHTML = "Loading...";
            notesHistory.innerHTML = "";
            notesTagsDisplay.innerHTML = "";

            Promise.all([
                fetch(`/notes/{{pod}}/${encodeURIComponent(epName)}`).then(r => r.json()),
                fetch(`/listening-stats/{{pod}}/${encodeURIComponent(epName)}`).then(r => r.json())
            ]).then(([notesData, statsData]) => {
                // Listening history summary
                if (statsData.success && statsData.totalListened > 0) {
                    let html = `<span class="stat-item"> listened: ${formatSecondsToHM(statsData.totalListened)}</span>`;
                    if (statsData.days && statsData.days.length > 0) {
                        html += '<div style="margin-top:6px; font-size:0.85em;">';
                        statsData.days.forEach(d => {
                            html += `<span class="stat-item">${d.date}: ${formatSecondsToHM(d.total_seconds)}</span>`;
                        });
                        html += '</div>';
                    }
                    notesHistory.innerHTML = html;
                } else {
                    notesHistory.innerHTML = "<em>No listening data yet.</em>";
                }

                // Notes content
                if (notesData.success) {
                    currentTags = notesData.tags || [];
                    notesTextarea.value = notesData.body;
                    renderNoteTags(notesTagsDisplay, currentTags);
                    if (notesData.body.trim()) {
                        notesDisplay.innerHTML = marked.parse(notesData.body);
                        notesDisplay.style.display = "block";
                        notesEditor.style.display = "none";
                        notesEditBtn.style.display = "inline-block";
                    } else {
                        // No notes yet — go straight to edit mode
                        notesDisplay.style.display = "none";
                        notesEditor.style.display = "block";
                        notesTagEditor.style.display = "block";
                        notesEditBtn.style.display = "none";
                        renderTagEditor();
                        notesTextarea.focus();
                    }
                } else {
                    notesDisplay.innerHTML = "<p>Error loading notes.</p>";
                }
            }).catch(err => {
                console.error("Error loading notes:", err);
                notesDisplay.innerHTML = "<p>Error loading notes.</p>";
            });
        });

        notesCloseBtn.addEventListener("click", () => {
            notesModal.style.display = "none";
        });

        window.addEventListener("click", (event) => {
            if (event.target == notesModal) {
                notesModal.style.display = "none";
            }
        });

        // Double-click notes display to enter edit mode
        const notesEditBtn = document.getElementById("notes-edit");
        notesEditBtn.addEventListener("click", () => {
            notesEditor.style.display = "block";
            notesTagEditor.style.display = "block";
            notesDisplay.style.display = "none";
            notesEditBtn.style.display = "none";
            renderTagEditor();
            notesTextarea.focus();
        });

        notesSaveBtn.addEventListener("click", () => {
            const body = notesTextarea.value;
            const content = buildFrontmatter(currentTags, body);
            fetch(`/notes/{{pod}}/${encodeURIComponent(epName)}`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ content })
            }).then(r => r.json()).then(data => {
                if (data.success) {
                    notesEditor.style.display = "none";
                    notesTagEditor.style.display = "none";
                    notesDisplay.style.display = "block";
                    notesEditBtn.style.display = "inline-block";
                    notesBtn.textContent = "📝";
                    notesBtn.style.opacity = "1";
                    currentTags = data.tags || currentTags;
                    renderNoteTags(notesTagsDisplay, currentTags);
                    if (body.trim()) {
                        notesDisplay.innerHTML = marked.parse(body);
                    } else {
                        notesDisplay.innerHTML = "";
                    }
                } else {
                    alert("Error saving notes: " + (data.message || "Unknown error"));
                }
            }).catch(err => {
                console.error("Error saving notes:", err);
                alert("Error saving notes.");
            });
        });

        notesCancelBtn.addEventListener("click", () => {
            notesEditor.style.display = "none";
            notesTagEditor.style.display = "none";
            notesDisplay.style.display = "block";
            notesEditBtn.style.display = "inline-block";
            // Re-fetch to restore tags to saved state
            fetch(`/notes/{{pod}}/${encodeURIComponent(epName)}`).then(r => r.json()).then(data => {
                if (data.success) {
                    currentTags = data.tags || [];
                    renderNoteTags(notesTagsDisplay, currentTags);
                }
            });
        });

        // Tag autocomplete
        let allTags = [];
        const notesTagSuggestions = document.getElementById("notes-tag-suggestions");
        let activeSuggestion = -1;

        fetch("/tags").then(r => r.json()).then(tags => { allTags = tags; }).catch(() => {});

        function showSuggestions(query) {
            const matches = allTags.filter(t =>
                t.toLowerCase().includes(query.toLowerCase()) && !currentTags.includes(t)
            );
            if (matches.length === 0 || !query) {
                notesTagSuggestions.style.display = "none";
                return;
            }
            activeSuggestion = -1;
            notesTagSuggestions.innerHTML = matches.map((t, i) =>
                `<div data-tag="${t}">${t}</div>`
            ).join("");
            notesTagSuggestions.style.display = "block";
            notesTagSuggestions.querySelectorAll("div").forEach(div => {
                div.addEventListener("mousedown", (e) => {
                    e.preventDefault();
                    const val = div.dataset.tag;
                    if (!currentTags.includes(val)) {
                        currentTags.push(val);
                        renderTagEditor();
                    }
                    notesTagInput.value = "";
                    notesTagSuggestions.style.display = "none";
                });
            });
        }

        notesTagInput.addEventListener("input", () => {
            showSuggestions(notesTagInput.value.trim());
        });

        notesTagInput.addEventListener("keydown", (e) => {
            const items = notesTagSuggestions.querySelectorAll("div");
            if (e.key === "ArrowDown") {
                e.preventDefault();
                activeSuggestion = Math.min(activeSuggestion + 1, items.length - 1);
                items.forEach((d, i) => d.classList.toggle("active", i === activeSuggestion));
            } else if (e.key === "ArrowUp") {
                e.preventDefault();
                activeSuggestion = Math.max(activeSuggestion - 1, 0);
                items.forEach((d, i) => d.classList.toggle("active", i === activeSuggestion));
            } else if (e.key === "Enter") {
                e.preventDefault();
                if (activeSuggestion >= 0 && items[activeSuggestion]) {
                    const val = items[activeSuggestion].dataset.tag;
                    if (!currentTags.includes(val)) {
                        currentTags.push(val);
                        renderTagEditor();
                    }
                    notesTagInput.value = "";
                    notesTagSuggestions.style.display = "none";
                } else {
                    addTag();
                }
            } else if (e.key === ",") {
                e.preventDefault();
                addTag();
            } else if (e.key === "Escape") {
                notesTagSuggestions.style.display = "none";
            }
        });

        notesTagInput.addEventListener("blur", () => {
            notesTagSuggestions.style.display = "none";
        });

        let searchMode = false;
      
        let storedFontSize = localStorage.getItem("fontSize");""
       let parsedSize = parseInt(storedFontSize, 10);

       if (!isNaN(parsedSize) && parsedSize >= FONTMIN && parsedSize <= FONTMAX) {
           fontSize = parsedSize;
       } else {
           fontSize = 30; // Default value
       }
    
        setFontSize()

        const whisperData = {{{ transcript }}}    

        function isIphone() {
            return /iPhone/i.test(navigator.userAgent);
        }   

      

        function setFontSize() {
            if (fontSize < FONTMIN) {
                fontSize = FONTMIN
            } else if (fontSize > FONTMAX) {
                fontSize = FONTMAX
            }
             transcriptionContainer.style.fontSize = `${fontSize}px`;
             localStorage.setItem("fontSize", fontSize)
        }

        function renderTranscription(data) {
            const paragraph = document.createElement("p");
            const lang = "{{info.language}}";

            // Set direction for Arabic
            if (lang === 'ar') {
                transcriptionContainer.setAttribute("dir", "rtl");
            } else {
                transcriptionContainer.setAttribute("dir", "ltr");
            }

            data.forEach(segment => {
                const phraseSpan = document.createElement("span");
                phraseSpan.classList.add("phrase");
                phraseSpan.dataset.start = segment.start;
                phraseSpan.dataset.end = segment.end;

                let words = [];
                if (lang === 'ja') {
                    const segmenter = new Intl.Segmenter('ja', { granularity: 'word' });
                    const segmented = segmenter.segment(segment.text);
                    for (const s of segmented) {
                        words.push(s.segment);
                    }
                } else if (lang === 'ar' && typeof Intl.Segmenter === "function") {
                    const segmenter = new Intl.Segmenter('ar', { granularity: 'word' });
                    const segmented = segmenter.segment(segment.text);
                    for (const s of segmented) {
                        words.push(s.segment);
                    }
                } else {
                    words = segment.text.split(/(\s+)/);
                }

                words.forEach(word => {
                    if (word.trim().length > 0) {
                        const wordSpan = document.createElement("span");
                        wordSpan.classList.add("word");
                        wordSpan.textContent = word;
                        phraseSpan.appendChild(wordSpan);
                    } else {
                        // Preserve whitespace
                        phraseSpan.appendChild(document.createTextNode(word));
                    }
                });

                paragraph.appendChild(phraseSpan);
            });

            transcriptionContainer.appendChild(paragraph);
        }

        // Render the Whisper data
        renderTranscription(whisperData);

        // Highlight current phrase based on audio time
        const phrases = document.querySelectorAll(".phrase");
        let currentPhraseIndex = -1;

        function highlightCurrentPhrase() {
            const currentTime = audio.currentTime;

            for (let i = 0; i < phrases.length; i++) {
                const start = parseFloat(phrases[i].dataset.start);
                const end = parseFloat(phrases[i].dataset.end);

                if (currentTime >= start && currentTime < end) {
                    if (currentPhraseIndex !== i) {
                        // Remove previous highlight
                        if (currentPhraseIndex !== -1) {
                            phrases[currentPhraseIndex].classList.remove("highlight");
                        }

                        // Highlight new phrase
                        phrases[i].classList.add("highlight");
                        phrases[i].scrollIntoView({ behavior: "smooth", block: "center" });

                        currentPhraseIndex = i;
                    }
                    return;
                }
            }

            // Remove highlight if no phrase matches
            if (currentPhraseIndex !== -1) {
                phrases[currentPhraseIndex].classList.remove("highlight");
                currentPhraseIndex = -1;
            }
        }

        function onDisplayChange() {
            currentPhraseIndex = -1; // Force re-evaluation and scroll
            highlightCurrentPhrase();
        }

        // Attach the timeupdate event listener
        audio.addEventListener("timeupdate", function () {
            updateTimeDisplay();
            highlightCurrentPhrase();
            updatePositionState();
        })

        transcriptionContainer.addEventListener("click", (event) => {
            if (searchMode) {
                // SEARCH MODE LOGIC
                const target = event.target;
                if (target.classList.contains("word")) {
                    const lang = "{{info.language}}";
                    let cleanWord = target.textContent.trim().replace(/[.,\/#!$%\^&\*;:{}=\-_`~()\?¿¡]/g, "");
                    // convert to lowercase for consistency
                    cleanWord = cleanWord.toLowerCase();
                    if (cleanWord) {
                        const phrase = target.closest('.phrase');
                        const segmentTime = phrase ? parseFloat(phrase.dataset.start) : audio.currentTime;

                        const displayNames = new Intl.DisplayNames(['en'], { type: 'language' });

                        const langName = displayNames.of(lang);

                        let url = ""
                        if (lang == "ja") {
                            url = `http://${window.location.hostname}:{{dictPort}}/search/${encodeURIComponent(cleanWord)}?podcast=${encodeURIComponent("{{pod}}")}&episode=${encodeURIComponent("{{{mp3file}}}")}&timestamp=${segmentTime}`;
                        } else if (lang == "sv") {
                            url = `https://folkets-lexikon.csc.kth.se/folkets/folkets.en.html#lookup&${cleanWord}&expandDirectly=t&presentQuestions=f`
                        } else if (lang == "es") {
                            url = `https://dle.rae.es/${cleanWord}`
                        }

                        // Use Wiktionary for other languages
                        else {
                            url = `https://en.wiktionary.org/wiki/${cleanWord}#${langName}`;
                        }

                        const lookupData = {
                            language: lang,
                            url: url,
                            word: cleanWord,
                            podcastName: "{{pod}}",
                            episodeName: "{{mp3file}}",
                            timestamp: segmentTime,
                            lookupTime: new Date().toISOString()
                        };

                        fetch('/log-lookup', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify(lookupData)
                        }).then(response => response.json()).then(data => {
                            if (data.success) {
                                console.log('Lookup logged successfully.');
                            } else {
                                console.error('Failed to log lookup:', data.message);
                            }
                        }).catch(error => {
                            console.error('Error logging lookup:', error);
                        });

                        window.open(url, '_blank');
                    }
                }
            } else {
                // LISTENING MODE LOGIC
                const phrase = event.target.closest('.phrase');
                if (phrase) {
                    const startTime = parseFloat(phrase.dataset.start);
                    audio.currentTime = startTime;
                    phrase.scrollIntoView({ behavior: "smooth", block: "center" });
                }
            }
        });

        // Update highlight when the page becomes visible
        document.addEventListener("visibilitychange", () => {
            if (document.visibilityState === "visible") {
                onDisplayChange();
                initMediaSession();
            }
        });

        // Update highlight on resize or orientation change
        window.addEventListener("resize", onDisplayChange);
        window.addEventListener("orientationchange", onDisplayChange);

        // More robust handling for mobile, especially iOS
        window.addEventListener("pageshow", onDisplayChange);

        // Audio control buttons
        function setStartTime() {
            audio.currentTime = {{ startTime }};
            seekSlider.max = audio.duration;
            seekSlider.disabled = false;
            initMediaSession();
        }

        seekSlider.addEventListener("input", function () {
            audio.currentTime = seekSlider.value;
            // updateHighlight();
        });

        audio.addEventListener("pause", () => {
            playpauseBtn.innerHTML = "▶"
            if ('mediaSession' in navigator) navigator.mediaSession.playbackState = 'paused';
            clearAllIntervals();
        })

        audio.addEventListener("ended", () => {
            playpauseBtn.innerHTML = "▶"
            if ('mediaSession' in navigator) navigator.mediaSession.playbackState = 'none';
            clearAllIntervals();
        })
        
        audio.addEventListener("play", () => {
            playpauseBtn.innerHTML = "⏸"
            if ('mediaSession' in navigator) navigator.mediaSession.playbackState = 'playing';
            restartAllIntervals();
        })



      
  function logMessage(message) {
    console.log(message);
    transcriptionContainer.insertAdjacentHTML("afterbegin", `<p>${message}</p>`);
}
audio.addEventListener("progress", () => {
    if (audio.buffered.length > 0) {
        const end = audio.buffered.end(0);
        if (end >= audio.duration) {
                playpauseBtn.style.backgroundColor = "green";
        }
    }
});

        audio.addEventListener("waiting", () => {
            playpauseBtn.style.backgroundColor = "orange";
        });
        audio.addEventListener("stalled", () => {
            playpauseBtn.style.backgroundColor = "orange";
        });
        audio.addEventListener("playing", () => {
            if (audio.buffered.length > 0 && audio.buffered.end(0) >= audio.duration) {
                playpauseBtn.style.backgroundColor = "green";
            } else {
                playpauseBtn.style.backgroundColor = "";
            }
        });
        audio.addEventListener("error", () => {
            playpauseBtn.style.backgroundColor = "red";
            logMessage("Audio error — try reloading");
        });

        audio.addEventListener("canplaythrough", setStartTime)


        function formatTime(seconds) {
            let min = Math.floor(seconds / 60);
            let sec = Math.floor(seconds % 60);
            return `${min}:${sec.toString().padStart(2, "0")}`;
        }
        function updateTimeDisplay() {
            let current = formatTime(audio.currentTime);
            let total = formatTime(audio.duration);
            seekSlider.value = audio.currentTime;
            timeDisplay.textContent = `${current} / ${total}`;
        }

        function updatePositionState() {
            if (!('mediaSession' in navigator) || !('setPositionState' in navigator.mediaSession)) return;
            if (isNaN(audio.duration) || audio.duration === 0) return;
            navigator.mediaSession.setPositionState({
                duration: audio.duration,
                playbackRate: audio.playbackRate,
                position: Math.min(audio.currentTime, audio.duration),
            });
        }

        function initMediaSession() {
            if (!('mediaSession' in navigator)) return;
            navigator.mediaSession.metadata = new MediaMetadata({
                title: decodedTitle,
                artist: "{{pod}}",
                artwork: [{ src: '/geticon?pod={{pod}}', sizes: '64x64', type: 'image/jpeg' }]
            });
            navigator.mediaSession.setActionHandler('play', () => {
                if (audio.readyState === 0) {
                    const savedTime = audio.currentTime;
                    audio.load();
                    audio.addEventListener('loadedmetadata', () => {
                        audio.currentTime = savedTime;
                        audio.play().catch(e => console.warn('MediaSession play after reload rejected:', e));
                    }, { once: true });
                } else {
                    audio.play().catch(e => console.warn('MediaSession play rejected:', e));
                }
            });
            navigator.mediaSession.setActionHandler('pause', () => audio.pause());
            navigator.mediaSession.setActionHandler('seekbackward', (d) => {
                audio.currentTime = Math.max(0, audio.currentTime - (d.seekOffset || 10));
            });
            navigator.mediaSession.setActionHandler('seekforward', (d) => {
                audio.currentTime = Math.min(audio.duration, audio.currentTime + (d.seekOffset || 10));
            });
            navigator.mediaSession.setActionHandler('seekto', (d) => {
                if (d.fastSeek && 'fastSeek' in audio) audio.fastSeek(d.seekTime);
                else audio.currentTime = d.seekTime;
            });
            // iOS needs prev/next registered to treat the session as fully controllable
            navigator.mediaSession.setActionHandler('previoustrack', () => {
                audio.currentTime = Math.max(0, audio.currentTime - 10);
            });
            navigator.mediaSession.setActionHandler('nexttrack', () => {
                audio.currentTime = Math.min(audio.duration, audio.currentTime + 10);
            });
        }

        // Register immediately — on iOS, canplaythrough won't fire until after first
        // user interaction, so waiting for it means the lock screen has no handlers.
        initMediaSession();

        playpauseBtn.addEventListener("click", () => {
            if (audio.paused) {
                audio.play();
            } else {
                saveMeta();
                audio.pause();
            }
        });

        finishBtn.addEventListener("click", () => {
            finished = true
            saveMeta(true)
        })


        backBtn.addEventListener("click", () => {
            saveMeta()
            localStorage.setItem("lastPage", "")
            window.location.href = "/pod/{{pod}}"
        });
        topBtn.addEventListener("click", () => {
            saveMeta()
            localStorage.setItem("lastPage", "")
            window.location.href = "/"
        });

        rewindBtn.addEventListener("click", () => {
            audio.currentTime = Math.max(0, audio.currentTime - 5);
        });

        toggleModeBtn.addEventListener("click", () => {
            searchMode = !searchMode;
            if (searchMode) {
                toggleModeBtn.textContent = "🔎";
                toggleModeBtn.style.backgroundColor = "lightblue";
            } else {
                toggleModeBtn.textContent = "👂";
                toggleModeBtn.style.backgroundColor = "";
            }
        });

        let saveMetaTimer = setInterval(() => {
            if (! (audio.paused))
                saveMeta()
        }, 15000);

        let listenTimeTimer = setInterval(() => {
            if (audioChanged()) {
                addListeningTime();
            }
        }, listenSecondsUpdateInterval * 1000);

        function clearAllIntervals() {
            clearInterval(saveMetaTimer);
            clearInterval(listenTimeTimer);
        }

        function restartAllIntervals() {
            clearAllIntervals();
            saveMetaTimer = setInterval(() => {
                if (!(audio.paused))
                    saveMeta();
            }, 15000);
            listenTimeTimer = setInterval(() => {
                if (audioChanged()) {
                    addListeningTime();
                }
            }, listenSecondsUpdateInterval * 1000);
        }

        window.addEventListener('pagehide', () => {
            clearAllIntervals();
            const meta = { finished, timeLastOpened, timeInPod: audio.currentTime };
            try {
                navigator.sendBeacon('/update-meta-ep',
                    new Blob([JSON.stringify({ name: "{{mp3file}}", ...meta })], { type: 'application/json' }));
            } catch (_) {}
        });

        function saveMeta(andNext = false) {
            let meta = { finished, timeLastOpened, timeInPod: audio.currentTime }
            fetch("/update-meta-ep", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ name: "{{mp3file}}", ...meta })
            })
                .then(response => response.json())
                .then(data => {
                    if (!data.success) {
                        alert(`Error: ${data.message}`);
                    } else {
                        console.log(`Updated meta for ${name}`);
                    }
                    if (andNext) {
                        {{#if nextep}}  
                        window.location.href = "/play/{{pod}}/{{{nextep}}}"
                        {{else}}
                        window.location.href = "/pod/{{pod}}"
                        {{/if}}
                    }
                })
                .catch(error => console.error("Fetch error:", error));

        }

        function audioChanged() 
        {
            const currentTime = audio.currentTime;
            // store currentTime in persistent variable

            // Check if the audio has changed
            if (currentTime !== lastTime) {
                lastTime = currentTime; // Update the last time
                return true; // Audio has changed
            }
            return false; // Audio is not playing
        }

    // Function to call the update-time endpoint
    function addListeningTime() {
        const date = new Date().toISOString().split('T')[0]; // Get the current date in YYYY-MM-DD format
        const podcastName = "{{pod}}"; // Use the current podcast name
        const episodeName = "{{mp3file}}"; // Use the current episode name
        
        fetch(`/update-time?date=${date}&podcastName=${encodeURIComponent(podcastName)}&episodeName=${encodeURIComponent(episodeName)}&seconds=${listenSecondsUpdateInterval}`)
            .then(response => response.json())
            .then(data => {
                if (!data.success) {
                    console.error(`Error updating time: ${data.message}`);
                } else {
                    console.log(`Time updated successfully for ${podcastName} - ${episodeName}`);
                    // Update the displayed time
                    const timeSpan = document.getElementById('timeListenedToday');
                    if (timeSpan && data.timeListenedToday) {
                        timeSpan.textContent = data.timeListenedToday;
                    }
                }
            })
            .catch(error => console.error("Fetch error:", error));
    }

});



</script>
